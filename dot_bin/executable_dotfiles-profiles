#!/usr/bin/env bash
set -euo pipefail

CHEZMOI_BASE_DIR="${XDG_DATA_HOME:-$HOME/.local/share}"
CHEZMOI_DIR="${CHEZMOI_BASE_DIR}/chezmoi"

get_github_user() {
    if [[ -d "${CHEZMOI_DIR}/.git" ]]; then
        local url
        url=$(git -C "${CHEZMOI_DIR}" remote get-url origin 2>/dev/null || true)
        if [[ "${url}" =~ github\.com[:/]([^/]+)/ ]]; then
            printf '%s' "${BASH_REMATCH[1]}"
            return
        fi
    fi
    gh api user --jq '.login'
}

if ! command -v gh &>/dev/null; then
    printf 'Error: GitHub CLI (gh) is required\n' >&2
    exit 1
fi

GITHUB_USER=$(get_github_user)
if [[ -z "${GITHUB_USER}" ]]; then
    printf 'Error: Could not determine GitHub username\n' >&2
    exit 1
fi

printf 'Searching for dotfiles profiles for: %s\n' "${GITHUB_USER}"

mapfile -t PROFILES < <(
    gh repo list "${GITHUB_USER}" --json name --limit 100 \
        --jq '.[].name | select(startswith("dotfiles.")) | ltrimstr("dotfiles.")'
)

if [[ ${#PROFILES[@]} -eq 0 ]]; then
    printf 'No dotfiles profiles found for %s\n' "${GITHUB_USER}"
    exit 0
fi

# Select profiles — prefer fzf multi-select, fall back to numbered menu
if command -v fzf &>/dev/null; then
    mapfile -t SELECTED < <(
        printf '%s\n' "${PROFILES[@]}" \
            | fzf --multi --prompt="Select profiles to install> " --height=40% \
            || true
    )
else
    printf '\nAvailable profiles:\n'
    for i in "${!PROFILES[@]}"; do
        local_dir="${CHEZMOI_BASE_DIR}/chezmoi-${PROFILES[$i]}"
        status="not installed"
        [[ -d "${local_dir}/.git" ]] && status="installed"
        printf '  [%d] %s (%s)\n' "$((i + 1))" "${PROFILES[$i]}" "${status}"
    done
    printf '\nSelect profiles (space-separated numbers, or "all"): '
    read -r selection
    SELECTED=()
    if [[ "${selection}" == "all" ]]; then
        SELECTED=("${PROFILES[@]}")
    else
        for num in ${selection}; do
            if [[ "${num}" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#PROFILES[@]} )); then
                SELECTED+=("${PROFILES[$((num - 1))]}")
            else
                printf 'Invalid selection: %s, skipping\n' "${num}"
            fi
        done
    fi
fi

if [[ ${#SELECTED[@]} -eq 0 ]]; then
    printf 'No profiles selected\n'
    exit 0
fi

for profile in "${SELECTED[@]}"; do
    dir="${CHEZMOI_BASE_DIR}/chezmoi-${profile}"
    printf '\n==> Profile: %s\n' "${profile}"
    if [[ -d "${dir}/.git" ]]; then
        printf '    Updating existing install at %s\n' "${dir}"
        chezmoi -S "${dir}" update
    else
        printf '    Cloning %s/dotfiles.%s -> %s\n' "${GITHUB_USER}" "${profile}" "${dir}"
        chezmoi -S "${dir}" init "${GITHUB_USER}/dotfiles.${profile}"
        chezmoi -S "${dir}" apply
    fi
done

printf '\nDone! Run the following to activate new aliases in this shell:\n'
printf '  source ~/.config/zsh/chezmoi-aliases.zsh\n'
